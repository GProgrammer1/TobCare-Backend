// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  output          = "../packages/prisma/generated"
  engineType      = "binary"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [citext]
}

enum UserRole {
  ADMIN
  DOCTOR
  PATIENT
}

enum BloodType {
  A_NEG
  A_POS
  B_NEG
  B_POS
  AB_NEG
  AB_POS
  O_POS
  O_NEG
}

enum Gender {
  M
  F
}

enum SmokingStatus {
  NEVER
  FORMER
  CURRENT
}

enum DrinkingStatus {
  NEVER
  OCCASIONAL
  REGULAR
}

enum Severity {
  MILD
  MODERATE
  SEVERE
}

model User {
  id           BigInt   @id @default(autoincrement())
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String   @unique @db.Citext
  role         UserRole
  passwordHash String   @map("password_hash")
  phoneNumber  String   @map("phone_number")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  patient      Patient?

  @@map("users")
}

model Patient {
  id                BigInt       @id @default(autoincrement())
  userId            BigInt       @unique @map("user_id")
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bloodType         BloodType      @map("blood_type")
  gender            Gender
  smokingStatus     SmokingStatus? @map("smoking_status")
  drinkingStatus    DrinkingStatus? @map("drinking_status")
  heightCm          Float        @map("height_cm")
  weightKg          Float        @map("weight_kg")
  dateOfBirth       String       @map("date_of_birth") @db.VarChar(64) // hmac256 encrypted
  emergencyContacts EmergencyContact[]
  createdAt         DateTime     @default(now()) @map("created_at")   @db.Timestamptz()
  updatedAt         DateTime     @updatedAt @map("updated_at")    @db.Timestamptz()
  medications       Medication[]
  diseases          Disease[]
  allergies         Allergy[]

  @@map("patients")
}

model Medication {
  id              BigInt   @id @default(autoincrement())
  patientId       BigInt?  @map("patient_id")
  patient         Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name            String
  dose            String
  frequency       String
  // prescribedAt DateTime? @map("prescribed_at")
  diseaseId       BigInt?  @map("disease_id")
  disease         Disease? @relation(fields: [diseaseId], references: [id], onDelete: SetNull)
  allergyId       BigInt?  @map("allergy_id")
  allergy         Allergy? @relation(fields: [allergyId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now()) @map("created_at")   @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at")    @db.Timestamptz()
  prescribedYear  Int?     @map("prescribed_year") // e.g. 2019
  prescribedMonth Int?     @map("prescribed_month") // 1-12, optional  @@map("medications")
  @@map("medications")
}

model Disease {
  id             BigInt       @id @default(autoincrement())
  patientId      BigInt?      @map("patient_id")
  patient        Patient?     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime     @default(now()) @map("created_at")    @db.Timestamptz()
  updatedAt      DateTime     @updatedAt @map("updated_at")   @db.Timestamptz()
  medications    Medication[]
  diagnosedYear  Int?         @map("diagnosed_year")
  diagnosedMonth Int?         @map("diagnosed_month")

  @@map("diseases")
}

model Allergy {
  id             BigInt       @id @default(autoincrement())
  patientId      BigInt?      @map("patient_id")
  patient        Patient?     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name           String
  severity       Severity // e.g. mild, moderate, severe
  createdAt      DateTime     @default(now()) @map("created_at")  @db.Timestamptz()
  updatedAt      DateTime     @updatedAt @map("updated_at")   @db.Timestamptz()
  medications    Medication[]
  diagnosedYear  Int?         @map("diagnosed_year")
  diagnosedMonth Int?         @map("diagnosed_month")

  @@map("allergies")
}

model EmergencyContact {
  id        BigInt   @id @default(autoincrement())
  patientId BigInt   @map("patient_id")
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name      String
  phoneNumber String @map("phone_number")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()
  @@map("emergency_contacts")
}

enum ApplicationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum NotificationType {
  NEW_APPLICATION
  APPLICATION_UPDATED
}

model Notification {
  id        BigInt           @id @default(autoincrement())
  type      NotificationType
  title     String
  message   String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  @@index([read, createdAt(sort: Desc)])
  @@map("notifications")
}


enum Governorate {
  BEIRUT
  MOUNT_LEBANON
  NORTH
  SOUTH
  BEKAA
  NABATIEH
  AKKAR
  BAALBEK_HERMEL
}

model Hospital {
  id                    BigInt            @id @default(autoincrement())
  name                  String
  doctorApplicationId   BigInt            @map("doctor_application_id")
  doctorApplication     DoctorApplication @relation(fields: [doctorApplicationId], references: [id], onDelete: Cascade)
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz()
  governorate           Governorate
  address               String?

  @@map("hospitals")
}

model Clinic {
  id                    BigInt            @id @default(autoincrement())
  name                  String
  address               String?
  governorate           Governorate
  consultationFee       Decimal?          @map("consultation_fee")
  doctorApplicationId   BigInt            @map("doctor_application_id")
  doctorApplication     DoctorApplication @relation(fields: [doctorApplicationId], references: [id], onDelete: Cascade)
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("clinics")
}

model DoctorApplication {
  id                    BigInt            @id @default(autoincrement())
  createdAt             DateTime          @default(now()) @db.Timestamptz()
  updatedAt             DateTime          @updatedAt @db.Timestamptz()

  // Personal
  firstName             String            @map("first_name")
  lastName              String            @map("last_name")
  email                 String            @unique
  phone                 String
  dateOfBirth           DateTime
  nationalIdNumber      String            @unique

  // Professional
  lopNumber             String            @unique
  mophLicenseNumber     String            @unique
  specialties           String[]
  isSpecialist          Boolean           @default(false)
  graduationCountry     String
  medicalSchool         String
  graduationYear        Int

  // Optional — doctor may work in clinic and/or hospital
  clinics               Clinic[]
  hospitals             Hospital[]
  acceptedInsurances    String[]          @map("accepted_insurances")

  // Document paths (local for now, s3 later)
  nationalIdDoc         String         @map("national_id_doc") // path
  lopCertificateDoc     String         @map("lop_certificate_doc") // path
  medicalDegreeDoc      String         @map("medical_degree_doc") // path
  mophLicenseDoc        String         @map("moph_license_doc") // path
  specialtyDocs         String[]          @map("specialty_docs") // multiple paths for multiple specialties
  colloquiumDoc         String?          @map("colloquium_doc") // only for foreign-trained
  criminalRecordDoc     String          @map("criminal_record_doc") // path
  passportPhotoDoc      String          @map("passport_photo_doc") // path

  // Verification
  status                ApplicationStatus @default(PENDING)
  verifiedAt            DateTime? @db.Timestamptz()
  verifiedBy            BigInt?           @map("verified_by") // admin id
  adminNotes            String?   @map("admin_notes")

  @@map("doctor_applications")
}
