<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <title>Verify Your Email — TobCare</title>

  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:AllowPNG/>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->

  <style>
    {{{styles}}}
  </style>
</head>
<body class="email-body" style="margin:0; padding:0; background-color:#F5F0E8;">

  <!-- Preheader (hidden preview text) -->
  <div style="display:none; max-height:0; overflow:hidden; mso-hide:all;">
    Your TobCare verification code is {{otp}}. It expires in {{otpTtlMinutes}} minutes.
  </div>

  <!-- Email Wrapper -->
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" class="email-wrapper" style="background-color:#F5F0E8; padding:40px 0;">
    <tr>
      <td align="center">

        <!-- Card -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="560" class="email-card" style="max-width:560px; background-color:#ffffff; border-radius:16px; overflow:hidden; box-shadow:0 4px 24px rgba(13,31,26,0.08);">

          <!-- Header -->
          <tr>
            <td class="email-header" style="background-color:#0D1F1A; padding:32px 40px; text-align:center;">
              <h1 class="email-header-logo" style="font-family:'Playfair Display',Georgia,serif; font-size:28px; font-weight:500; color:#F5F0E8; letter-spacing:1px; margin:0;">
                TobCare
              </h1>
              <div class="email-header-accent" style="display:block; width:40px; height:3px; background-color:#C9A84C; margin:12px auto 0; border-radius:2px;"></div>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td class="email-content" style="padding:40px 40px 32px;">

              <!-- Greeting -->
              <p class="email-greeting" style="font-family:'DM Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-size:16px; font-weight:400; color:#1A2E28; line-height:1.6; margin:0 0 8px;">
                Hi {{firstName}},
              </p>

              <!-- Heading -->
              <h2 class="email-heading" style="font-family:'Playfair Display',Georgia,serif; font-size:22px; font-weight:500; color:#0D1F1A; line-height:1.3; margin:0 0 16px;">
                Your verification code
              </h2>

              <!-- Description -->
              <p class="email-text" style="font-family:'DM Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-size:15px; font-weight:300; color:#1A2E28; line-height:1.7; margin:0 0 28px;">
                Use the code below to verify your email address. Please do not share this code with anyone.
              </p>

              <!-- OTP Code -->
              <div class="otp-container" style="text-align:center; padding:24px 0 28px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" class="otp-table" style="margin:0 auto;">
                  <tr>
                    {{#each otpDigits}}
                    {{#unless @first}}
                    <td class="otp-spacer" style="width:10px;"></td>
                    {{/unless}}
                    <td class="otp-digit" style="width:52px; height:64px; background-color:#E8D5C4; border-radius:12px; text-align:center; vertical-align:middle; font-family:'DM Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-size:28px; font-weight:600; color:#2D5A4A;">
                      {{this}}
                    </td>
                    {{/each}}
                  </tr>
                </table>
              </div>

              <!-- Expiry -->
              <div class="email-expiry" style="text-align:center; padding:0 0 8px;">
                <p class="email-expiry-text" style="font-family:'DM Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-size:13px; font-weight:500; color:#6B8C82; letter-spacing:0.5px; text-transform:uppercase; margin:0;">
                  Expires in {{otpTtlMinutes}} minutes
                </p>
              </div>

            </td>
          </tr>

          <!-- Divider -->
          <tr>
            <td>
              <hr class="email-divider" style="border:none; height:2px; background-color:#7EC8A4; margin:0 40px 0; border-radius:1px; opacity:0.4;">
            </td>
          </tr>

          <!-- Security Notice -->
          <tr>
            <td class="email-security" style="padding:24px 40px 32px;">
              <p class="email-security-text" style="font-family:'DM Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-size:13px; font-weight:400; color:#6B8C82; line-height:1.7; margin:0;">
                If you didn't request this code, you can safely ignore this email. Someone may have entered your email address by mistake.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td class="email-footer" style="background-color:#0D1F1A; padding:24px 40px; text-align:center;">
              <p class="email-footer-brand" style="font-family:'Playfair Display',Georgia,serif; font-size:16px; font-weight:400; color:#7EC8A4; margin:0 0 4px; letter-spacing:0.5px;">
                TobCare
              </p>
              <p class="email-footer-text" style="font-family:'DM Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; font-size:12px; font-weight:300; color:#6B8C82; margin:0;">
                &copy; {{year}} TobCare. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
        <!-- /Card -->

      </td>
    </tr>
  </table>
  <!-- /Email Wrapper -->

</body>
</html>
